# MCP self-hosted AppFlowy test overrides.
# This file is appended to the upstream AppFlowy-Cloud deploy.env copy.

FQDN=localhost
SCHEME=http
APPFLOWY_BASE_URL=http://localhost
APPFLOWY_WEBSOCKET_BASE_URL=ws://localhost/ws/v2
APPFLOWY_WEB_URL=http://localhost
API_EXTERNAL_URL=http://localhost/gotrue

GOTRUE_ADMIN_EMAIL=admin@example.com
GOTRUE_ADMIN_PASSWORD=password
GOTRUE_JWT_SECRET=appflowy-mcp-local-test-jwt-secret
GOTRUE_JWT_EXP=7200
GOTRUE_MAILER_AUTOCONFIRM=true
GOTRUE_DISABLE_SIGNUP=false
GOTRUE_RATE_LIMIT_EMAIL_SENT=100

GOTRUE_EXTERNAL_GOOGLE_ENABLED=false
GOTRUE_EXTERNAL_GITHUB_ENABLED=false
GOTRUE_EXTERNAL_DISCORD_ENABLED=false
GOTRUE_EXTERNAL_APPLE_ENABLED=false
GOTRUE_SAML_ENABLED=false

APPFLOWY_S3_USE_MINIO=true
APPFLOWY_S3_CREATE_BUCKET=true
AWS_ACCESS_KEY=minioadmin
AWS_SECRET=minioadmin

APPFLOWY_ACCESS_CONTROL=true

APPFLOWY_CLOUD_VERSION=0.15.17
APPFLOWY_WEB_VERSION=0.13.3
APPFLOWY_WORKER_VERSION=0.15.17
APPFLOWY_AI_VERSION=0.15.10
GOTRUE_VERSION=0.15.17
APPFLOWY_ADMIN_FRONTEND_VERSION=0.15.17

NGINX_PORT=80
NGINX_TLS_PORT=443
