APPFLOWY_BASE_URL=https://beta.appflowy.cloud
APPFLOWY_ACCESS_TOKEN=replace-with-token
APPFLOWY_REFRESH_TOKEN=
APPFLOWY_TIMEOUT_SECONDS=30
APPFLOWY_ALLOW_WRITES=false
APPFLOWY_ALLOW_COLLAB_WRITES=false

# Optional live acceptance tests. Must point to a disposable workspace/database.
APPFLOWY_LIVE_TESTS=false
APPFLOWY_LIVE_WORKSPACE_ID=
APPFLOWY_LIVE_DATABASE_ID=
